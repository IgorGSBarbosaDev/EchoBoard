<Page
    x:Class="EchoBoard.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:EchoBoard.App.Controls"
    Loaded="OnLoaded">
    <ScrollViewer>
        <StackPanel Spacing="{StaticResource EchoBoardSpace24}">
            <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                <TextBlock
                    Text="{Binding Title}"
                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                    FontSize="{StaticResource EchoBoardFontSizeTitle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding Subtitle}"
                    Style="{StaticResource EchoBoardCaptionTextStyle}" />
            </StackPanel>

            <Border Style="{StaticResource EchoBoardPanelStyle}">
                <StackPanel Spacing="{StaticResource EchoBoardSpace12}">
                    <TextBlock Text="Microphone input" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                    <TextBlock
                        Text="Select a physical input device and start capture when you want to feed the future mixer."
                        Style="{StaticResource EchoBoardCaptionTextStyle}" />

                    <Grid ColumnSpacing="{StaticResource EchoBoardSpace16}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            MinWidth="320"
                            AutomationProperties.Name="Microphone device"
                            ItemsSource="{Binding MicrophoneDevices}"
                            DisplayMemberPath="DisplayName"
                            SelectedItem="{Binding SelectedMicrophoneDevice, Mode=TwoWay}"
                            PlaceholderText="Choose microphone" />
                        <Button
                            Grid.Column="1"
                            Content="Refresh"
                            Command="{Binding RefreshMicrophoneDevicesCommand}"
                            Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                        <Button
                            Grid.Column="2"
                            Content="Start"
                            Command="{Binding StartMicrophoneCaptureCommand}"
                            Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                        <Button
                            Grid.Column="3"
                            Content="Stop"
                            Command="{Binding StopMicrophoneCaptureCommand}"
                            Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                    </Grid>

                    <controls:DeviceStatusBadge
                        Label="Selected microphone"
                        DeviceName="{Binding SelectedMicrophoneName}"
                        Icon="Microphone"
                        Status="{Binding MicrophoneStatusKind}" />

                    <Grid ColumnSpacing="{StaticResource EchoBoardSpace16}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <controls:AudioLevelMeter
                            Label="Input level"
                            Level="{Binding MicrophoneLevel}"
                            Variant="Microphone"
                            ValueText="{Binding MicrophoneLevelText}" />
                        <controls:VolumeSlider
                            Grid.Column="1"
                            Label="Mic gain"
                            Icon="Microphone"
                            Value="{Binding MicrophoneGainPercent, Mode=TwoWay}"
                            IsReadOnly="False" />
                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Content="{Binding MicrophoneMuteButtonText}"
                            Command="{Binding ToggleMicrophoneMuteCommand}"
                            Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource EchoBoardPanelStyle}">
                <StackPanel Spacing="{StaticResource EchoBoardSpace12}">
                    <TextBlock Text="Global hotkeys" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                    <TextBlock
                        Text="Keyboard shortcuts work while EchoBoard is minimized or out of focus. Use at least one modifier plus one primary key."
                        Style="{StaticResource EchoBoardCaptionTextStyle}" />
                    <controls:ToastNotification
                        Kind="{Binding FeedbackToast.Kind}"
                        Title="{Binding FeedbackToast.Title}"
                        Description="{Binding FeedbackToast.Description}"
                        Visibility="{Binding FeedbackToastVisibility}" />
                    <ItemsControl ItemsSource="{Binding GlobalHotkeys}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,12"
                                    Style="{StaticResource EchoBoardCardStyle}">
                                    <Grid ColumnSpacing="{StaticResource EchoBoardSpace16}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="280" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="{StaticResource EchoBoardSpace4}">
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource EchoBoardCaptionTextStyle}" />
                                            <controls:HotkeyBadge Text="{Binding HotkeyText}" />
                                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource EchoBoardCaptionTextStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="{StaticResource EchoBoardSpace8}">
                                            <controls:HotkeyCaptureBox
                                                Ctrl="{Binding Ctrl, Mode=TwoWay}"
                                                Alt="{Binding Alt, Mode=TwoWay}"
                                                Shift="{Binding Shift, Mode=TwoWay}"
                                                Win="{Binding Win, Mode=TwoWay}"
                                                PrimaryKey="{Binding PrimaryKey, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Spacing="{StaticResource EchoBoardSpace8}">
                                            <Button
                                                Content="Save"
                                                Command="{Binding SaveCommand}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                                            <Button
                                                Content="{Binding ToggleEnabledText}"
                                                Command="{Binding ToggleEnabledCommand}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                                            <Button
                                                Content="Remove"
                                                Command="{Binding RemoveCommand}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
