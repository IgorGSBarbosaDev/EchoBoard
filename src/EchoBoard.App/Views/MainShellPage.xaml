<Page
    x:Class="EchoBoard.App.Views.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:EchoBoard.App.ViewModels"
    xmlns:views="using:EchoBoard.App.Views">
    <Page.Resources>
        <DataTemplate x:Key="DashboardTemplate">
            <views:DashboardPage />
        </DataTemplate>
        <DataTemplate x:Key="LibraryTemplate">
            <views:LibraryPage />
        </DataTemplate>
        <DataTemplate x:Key="FavoritesTemplate">
            <views:FavoritesPage />
        </DataTemplate>
        <DataTemplate x:Key="RecentTemplate">
            <views:RecentPage />
        </DataTemplate>
        <DataTemplate x:Key="SettingsTemplate">
            <views:SettingsPage />
        </DataTemplate>
        <DataTemplate x:Key="AudioDiagnosticsTemplate">
            <views:AudioDiagnosticsPage />
        </DataTemplate>
        <views:ShellPageTemplateSelector
            x:Key="ShellPageTemplateSelector"
            AudioDiagnosticsTemplate="{StaticResource AudioDiagnosticsTemplate}"
            DashboardTemplate="{StaticResource DashboardTemplate}"
            FavoritesTemplate="{StaticResource FavoritesTemplate}"
            LibraryTemplate="{StaticResource LibraryTemplate}"
            RecentTemplate="{StaticResource RecentTemplate}"
            SettingsTemplate="{StaticResource SettingsTemplate}" />
    </Page.Resources>

    <Grid
        Background="{ThemeResource EchoBoardBackgroundPrimaryBrush}"
        RequestedTheme="{Binding RequestedTheme}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Grid
            Padding="24,16"
            BorderBrush="{ThemeResource EchoBoardBorderBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="{StaticResource EchoBoardSpace16}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="{StaticResource EchoBoardSpace12}">
                <SymbolIcon
                    Foreground="{ThemeResource EchoBoardActionBrush}"
                    Symbol="Audio" />
                <TextBlock
                    VerticalAlignment="Center"
                    Text="{Binding Title}"
                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                    FontSize="{StaticResource EchoBoardFontSizeSectionTitle}"
                    FontWeight="SemiBold" />
            </StackPanel>

            <TextBox
                Grid.Column="1"
                MaxWidth="460"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                AutomationProperties.Name="Search sounds placeholder"
                IsTabStop="True"
                PlaceholderText="{Binding SearchPlaceholder}"
                Style="{StaticResource EchoBoardSearchTextBoxStyle}" />

            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="{StaticResource EchoBoardSpace8}">
                <Border Style="{StaticResource EchoBoardStatusBadgeStyle}">
                    <TextBlock
                        Foreground="{ThemeResource EchoBoardSuccessBrush}"
                        FontSize="{StaticResource EchoBoardFontSizeBadge}"
                        FontWeight="SemiBold"
                        Text="{Binding MicrophoneStatusLabel}" />
                </Border>
                <Border Style="{StaticResource EchoBoardStatusBadgeStyle}">
                    <TextBlock
                        Foreground="{ThemeResource EchoBoardWarningBrush}"
                        FontSize="{StaticResource EchoBoardFontSizeBadge}"
                        FontWeight="SemiBold"
                        Text="{Binding VirtualOutputStatusLabel}" />
                </Border>
                <Button
                    AutomationProperties.Name="Switch theme"
                    Command="{Binding ToggleThemeCommand}"
                    Content="Theme"
                    Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                <Button
                    AutomationProperties.Name="Open settings"
                    Command="{Binding OpenSettingsCommand}"
                    Style="{StaticResource EchoBoardIconButtonStyle}"
                    ToolTipService.ToolTip="Settings">
                    <SymbolIcon Symbol="Setting" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <NavigationView
                AlwaysShowHeader="False"
                Background="{ThemeResource EchoBoardBackgroundPrimaryBrush}"
                CompactPaneLength="56"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                MenuItemsSource="{Binding NavigationItems}"
                OpenPaneLength="224"
                PaneDisplayMode="LeftCompact"
                SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}">
                <NavigationView.MenuItemTemplate>
                    <DataTemplate>
                        <StackPanel
                            AutomationProperties.Name="{Binding AutomationName}"
                            Orientation="Horizontal"
                            Spacing="{StaticResource EchoBoardSpace12}">
                            <SymbolIcon
                                Foreground="{ThemeResource EchoBoardTextSecondaryBrush}"
                                Symbol="{Binding Icon}" />
                            <TextBlock
                                Text="{Binding Label}"
                                Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                                FontSize="{StaticResource EchoBoardFontSizeControl}" />
                        </StackPanel>
                    </DataTemplate>
                </NavigationView.MenuItemTemplate>

                <Grid Padding="{StaticResource EchoBoardPagePadding}" ColumnSpacing="{StaticResource EchoBoardSpace16}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{Binding ContextPanelColumnWidth}" />
                    </Grid.ColumnDefinitions>

                    <ContentControl
                        Content="{Binding CurrentPage}"
                        ContentTemplateSelector="{StaticResource ShellPageTemplateSelector}" />

                    <Border
                        Grid.Column="1"
                        Style="{StaticResource EchoBoardPanelStyle}"
                        Visibility="{Binding ContextPanelVisibility}">
                        <StackPanel Spacing="{StaticResource EchoBoardSpace16}">
                            <Grid ColumnSpacing="{StaticResource EchoBoardSpace12}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="{StaticResource EchoBoardSpace4}">
                                    <TextBlock
                                        Text="{Binding ContextPanelTitle}"
                                        Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                                    <TextBlock
                                        Text="{Binding ContextPanelSubtitle}"
                                        Style="{StaticResource EchoBoardCaptionTextStyle}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    AutomationProperties.Name="Collapse context panel"
                                    Command="{Binding ToggleContextPanelCommand}"
                                    Content="&gt;"
                                    Style="{StaticResource EchoBoardIconButtonStyle}" />
                            </Grid>

                            <Border Style="{StaticResource EchoBoardCardStyle}">
                                <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                                    <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Queue" />
                                    <TextBlock Style="{StaticResource EchoBoardBodyTextStyle}" Text="No active sounds" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource EchoBoardCardStyle}">
                                <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                                    <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Devices" />
                                    <TextBlock Style="{StaticResource EchoBoardBodyTextStyle}" Text="Device state is mocked in this phase." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </NavigationView>

            <Button
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,24,24,0"
                AutomationProperties.Name="Expand context panel"
                Command="{Binding ToggleContextPanelCommand}"
                Content="Panel"
                Visibility="{Binding ContextPanelExpandButtonVisibility}"
                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
        </Grid>

        <Border
            Grid.Row="2"
            Padding="24,16"
            Background="{ThemeResource EchoBoardBackgroundSurfaceBrush}"
            BorderBrush="{ThemeResource EchoBoardBorderBrush}"
            BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="{StaticResource EchoBoardSpace16}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    VerticalAlignment="Center"
                    Spacing="{StaticResource EchoBoardSpace8}">
                    <TextBlock
                        Text="{Binding CurrentSoundTitle}"
                        Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                    <TextBlock
                        Text="{Binding CurrentSoundSubtitle}"
                        Style="{StaticResource EchoBoardCaptionTextStyle}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="{StaticResource EchoBoardSpace12}">
                    <Slider
                        AutomationProperties.Name="Playback progress placeholder"
                        IsEnabled="False"
                        Maximum="100"
                        Minimum="0"
                        Style="{StaticResource EchoBoardSliderStyle}"
                        Value="0" />
                    <Grid ColumnSpacing="{StaticResource EchoBoardSpace12}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource EchoBoardSpace8}">
                            <Button Content="Play" IsEnabled="False" Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                            <Button Content="Pause" IsEnabled="False" Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                            <Button Content="Stop" IsEnabled="False" Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="{StaticResource EchoBoardSpace4}">
                            <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Mic" />
                            <Slider IsEnabled="False" Maximum="100" Minimum="0" Style="{StaticResource EchoBoardSliderStyle}" Value="75" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="{StaticResource EchoBoardSpace4}">
                            <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Effects" />
                            <Slider IsEnabled="False" Maximum="100" Minimum="0" Style="{StaticResource EchoBoardSliderStyle}" Value="80" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="{StaticResource EchoBoardSpace4}">
                            <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Monitor" />
                            <Slider IsEnabled="False" Maximum="100" Minimum="0" Style="{StaticResource EchoBoardSliderStyle}" Value="60" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Style="{StaticResource EchoBoardStatusBadgeStyle}">
                    <TextBlock
                        Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                        FontSize="{StaticResource EchoBoardFontSizeBadge}"
                        FontWeight="SemiBold"
                        Text="{Binding VirtualOutputStateLabel}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
