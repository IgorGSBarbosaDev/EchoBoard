<Page
    x:Class="EchoBoard.App.Views.AudioDiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:EchoBoard.App.Controls">
    <ScrollViewer>
        <StackPanel Spacing="{StaticResource EchoBoardSpace24}">
            <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                <TextBlock
                    Text="{Binding Title}"
                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                    FontSize="{StaticResource EchoBoardFontSizeTitle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding Subtitle}"
                    Style="{StaticResource EchoBoardCaptionTextStyle}" />
            </StackPanel>

            <Border Style="{StaticResource EchoBoardPanelStyle}">
                <StackPanel Spacing="{StaticResource EchoBoardSpace16}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace12}">
                        <TextBlock
                            Text="{Binding EmptyStateTitle}"
                            Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                        <TextBlock
                            Text="{Binding EmptyStateMessage}"
                            Style="{StaticResource EchoBoardBodyTextStyle}" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding PreviewDevices}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource EchoBoardSpace8}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:DeviceStatusBadge
                                    Label="{Binding Label}"
                                    DeviceName="{Binding DeviceName}"
                                    Icon="{Binding Icon}"
                                    Status="{Binding Status}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding PreviewMeters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource EchoBoardSpace16}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:AudioLevelMeter
                                    Width="180"
                                    Label="{Binding Label}"
                                    Level="{Binding Level}"
                                    Variant="{Binding Variant}"
                                    ValueText="{Binding ValueText}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
