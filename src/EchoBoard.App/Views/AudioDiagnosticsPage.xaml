<Page
    x:Class="EchoBoard.App.Views.AudioDiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="{StaticResource EchoBoardSpace24}">
            <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                <TextBlock
                    Text="{Binding Title}"
                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                    FontSize="{StaticResource EchoBoardFontSizeTitle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding Subtitle}"
                    Style="{StaticResource EchoBoardCaptionTextStyle}" />
            </StackPanel>

            <Border Style="{StaticResource EchoBoardPanelStyle}">
                <StackPanel Spacing="{StaticResource EchoBoardSpace16}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace12}">
                        <TextBlock
                            Text="{Binding EmptyStateTitle}"
                            Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                        <TextBlock
                            Text="{Binding EmptyStateMessage}"
                            Style="{StaticResource EchoBoardBodyTextStyle}" />
                    </StackPanel>
                    <Grid ColumnSpacing="{StaticResource EchoBoardSpace12}" RowSpacing="{StaticResource EchoBoardSpace12}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource EchoBoardStatusBadgeStyle}">
                            <TextBlock
                                Foreground="{ThemeResource EchoBoardWarningBrush}"
                                FontSize="{StaticResource EchoBoardFontSizeBadge}"
                                FontWeight="SemiBold"
                                Text="Mic mock state" />
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource EchoBoardStatusBadgeStyle}">
                            <TextBlock
                                Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                                FontSize="{StaticResource EchoBoardFontSizeBadge}"
                                FontWeight="SemiBold"
                                Text="Engine offline" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
