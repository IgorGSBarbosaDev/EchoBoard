<Page
    x:Class="EchoBoard.App.Views.AudioDiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:EchoBoard.App.Controls">
    <ScrollViewer>
        <StackPanel Spacing="{StaticResource EchoBoardSpace24}">
            <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                <TextBlock
                    Text="{Binding Title}"
                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                    FontSize="{StaticResource EchoBoardFontSizeTitle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding Subtitle}"
                    Style="{StaticResource EchoBoardCaptionTextStyle}" />
            </StackPanel>

            <Border Style="{StaticResource EchoBoardPanelStyle}">
                <StackPanel Spacing="{StaticResource EchoBoardSpace16}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace12}">
                        <TextBlock
                            Text="{Binding EmptyStateTitle}"
                            Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                        <TextBlock
                            Text="{Binding EmptyStateMessage}"
                            Style="{StaticResource EchoBoardBodyTextStyle}" />
                    </StackPanel>

                    <controls:DeviceStatusBadge
                        Label="{Binding MicrophoneDevice.Label}"
                        DeviceName="{Binding MicrophoneDevice.DeviceName}"
                        Icon="{Binding MicrophoneDevice.Icon}"
                        Status="{Binding MicrophoneDevice.Status}" />

                    <controls:AudioLevelMeter
                        Width="240"
                        Label="{Binding MicrophoneMeter.Label}"
                        Level="{Binding MicrophoneMeter.Level}"
                        Variant="{Binding MicrophoneMeter.Variant}"
                        ValueText="{Binding MicrophoneMeter.ValueText}" />

                    <StackPanel Spacing="{StaticResource EchoBoardSpace4}">
                        <TextBlock Text="{Binding FormatText}" Style="{StaticResource EchoBoardCaptionTextStyle}" />
                        <TextBlock Text="{Binding LastErrorText}" Style="{StaticResource EchoBoardBodyTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
