<Page
    x:Class="EchoBoard.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:EchoBoard.App.Controls">
    <ScrollViewer>
        <StackPanel Spacing="{StaticResource EchoBoardSpace24}">
            <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                <TextBlock
                    Text="{Binding Title}"
                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                    FontSize="{StaticResource EchoBoardFontSizeTitle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding Subtitle}"
                    Style="{StaticResource EchoBoardCaptionTextStyle}" />
            </StackPanel>

            <Grid ColumnSpacing="{StaticResource EchoBoardSpace16}" RowSpacing="{StaticResource EchoBoardSpace16}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource EchoBoardCardStyle}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                        <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Library" />
                        <TextBlock Foreground="{ThemeResource EchoBoardTextPrimaryBrush}" FontSize="28" FontWeight="SemiBold" Text="0 sounds" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource EchoBoardCardStyle}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                        <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Hotkeys" />
                        <TextBlock Foreground="{ThemeResource EchoBoardTextPrimaryBrush}" FontSize="28" FontWeight="SemiBold" Text="Not set" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource EchoBoardCardStyle}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                        <TextBlock Style="{StaticResource EchoBoardCaptionTextStyle}" Text="Routing" />
                        <TextBlock Foreground="{ThemeResource EchoBoardTextPrimaryBrush}" FontSize="28" FontWeight="SemiBold" Text="Idle" />
                    </StackPanel>
                </Border>
            </Grid>

            <controls:ToastNotification
                Kind="{Binding PreviewToast.Kind}"
                Title="{Binding PreviewToast.Title}"
                Description="{Binding PreviewToast.Description}" />

            <Border Style="{StaticResource EchoBoardPanelStyle}">
                <StackPanel Spacing="{StaticResource EchoBoardSpace16}">
                    <TextBlock Text="Reusable sound cards" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                    <ItemsControl ItemsSource="{Binding PreviewSounds}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource EchoBoardSpace12}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:SoundCard
                                    Width="236"
                                    Title="{Binding Title}"
                                    Subtitle="{Binding Subtitle}"
                                    DurationText="{Binding DurationText}"
                                    HotkeyText="{Binding HotkeyText}"
                                    CategoryLabel="{Binding CategoryLabel}"
                                    CategoryBrush="{Binding CategoryBrush}"
                                    IsSelected="{Binding IsSelected}"
                                    IsPlaying="{Binding IsPlaying}"
                                    IsFavorite="{Binding IsFavorite}"
                                    IsCompact="{Binding IsCompact}"
                                    IsEnabled="{Binding IsEnabled}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <controls:EmptyState
                Icon="{Binding PreviewEmptyState.Icon}"
                Title="{Binding PreviewEmptyState.Title}"
                Description="{Binding PreviewEmptyState.Description}"
                PrimaryActionText="{Binding PreviewEmptyState.PrimaryActionText}"
                SecondaryActionText="{Binding PreviewEmptyState.SecondaryActionText}" />
        </StackPanel>
    </ScrollViewer>
</Page>
