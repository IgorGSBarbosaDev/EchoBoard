<Page
    x:Class="EchoBoard.App.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:EchoBoard.App.Controls"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">
    <ScrollViewer>
        <StackPanel
            AllowDrop="True"
            DragOver="OnDragOver"
            Drop="OnDrop"
            Spacing="{StaticResource EchoBoardSpace24}">
            <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                <TextBlock
                    Text="{Binding Title}"
                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                    FontSize="{StaticResource EchoBoardFontSizeTitle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="{Binding Subtitle}"
                    Style="{StaticResource EchoBoardCaptionTextStyle}" />
            </StackPanel>

            <Grid ColumnSpacing="{StaticResource EchoBoardSpace16}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource EchoBoardPanelStyle}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace16}">
                        <TextBlock Text="Categories" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:CategoryItem
                                        Margin="0,0,0,8"
                                        CategoryName="{Binding Name}"
                                        CountText="{Binding CountText}"
                                        Icon="{Binding Icon}"
                                        IndicatorBrush="{Binding IndicatorBrush}"
                                        IsSelected="{Binding IsSelected}"
                                        IsEnabled="{Binding IsEnabled}"
                                        Command="{Binding SelectCommand}"
                                        CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                            <TextBlock Text="Create category" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                            <TextBox
                                x:Name="CreateCategoryNameTextBox"
                                Header="Name"
                                PlaceholderText="Memes" />
                            <Button
                                Content="Create"
                                Click="OnCreateCategoryClicked"
                                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                        </StackPanel>

                        <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                            <TextBlock Text="Selected category" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                            <TextBox
                                x:Name="RenameCategoryNameTextBox"
                                Header="New name"
                                PlaceholderText="Rename selected category" />
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource EchoBoardSpace8}">
                                <Button
                                    Content="Rename"
                                    Click="OnRenameCategoryClicked"
                                    Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                                <Button
                                    Content="Delete"
                                    Click="OnDeleteCategoryClicked"
                                    Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                            <TextBlock Text="Selected sound" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                            <ComboBox
                                x:Name="AssignCategoryComboBox"
                                Header="Assign category"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding AssignableCategories}" />
                            <Button
                                Content="Apply category"
                                Click="OnAssignSelectedCategoryClicked"
                                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                        </StackPanel>

                        <StackPanel
                            Spacing="{StaticResource EchoBoardSpace8}"
                            Visibility="{Binding SoundHotkeyEditorVisibility}">
                            <TextBlock Text="Hotkey" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                            <TextBlock Text="{Binding SelectedSoundHotkeyText}" Style="{StaticResource EchoBoardCaptionTextStyle}" />
                            <controls:HotkeyCaptureBox
                                Ctrl="{Binding HotkeyCtrl, Mode=TwoWay}"
                                Alt="{Binding HotkeyAlt, Mode=TwoWay}"
                                Shift="{Binding HotkeyShift, Mode=TwoWay}"
                                Win="{Binding HotkeyWin, Mode=TwoWay}"
                                PrimaryKey="{Binding HotkeyPrimaryKey, Mode=TwoWay}" />
                            <CheckBox Content="Enabled" IsChecked="{Binding IsSelectedSoundHotkeyEnabled, Mode=TwoWay}" />
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource EchoBoardSpace8}">
                                <Button
                                    Content="Save"
                                    Command="{Binding SaveSoundHotkeyCommand}"
                                    Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                                <Button
                                    Content="Remove"
                                    Command="{Binding RemoveSoundHotkeyCommand}"
                                    Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource EchoBoardPanelStyle}">
                    <StackPanel Spacing="{StaticResource EchoBoardSpace16}">
                        <Grid ColumnSpacing="{StaticResource EchoBoardSpace12}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Header="Search"
                                PlaceholderText="Find sounds by name"
                                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                Content="Clear filters"
                                Command="{Binding ClearFiltersCommand}"
                                Visibility="{Binding ClearFiltersVisibility}"
                                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                            <Button
                                Grid.Column="2"
                                AutomationProperties.Name="Import sounds"
                                Click="OnImportClicked"
                                Content="{Binding ImportButtonText}"
                                IsEnabled="{Binding IsImportEnabled}"
                                Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                        </Grid>

                        <controls:ToastNotification
                            Kind="{Binding ImportToast.Kind}"
                            Title="{Binding ImportToast.Title}"
                            Description="{Binding ImportToast.Description}"
                            DismissCommand="{Binding DismissImportFeedbackCommand}"
                            Visibility="{Binding ImportToastVisibility}" />

                        <controls:ToastNotification
                            Kind="{Binding PlaybackToast.Kind}"
                            Title="{Binding PlaybackToast.Title}"
                            Description="{Binding PlaybackToast.Description}"
                            DismissCommand="{Binding DismissPlaybackFeedbackCommand}"
                            Visibility="{Binding PlaybackToastVisibility}" />

                        <Border
                            Style="{StaticResource EchoBoardCardStyle}"
                            Visibility="{Binding ImportFeedbackVisibility}">
                            <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
                                <TextBlock Text="Import details" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                                <ItemsControl ItemsSource="{Binding ImportFeedbackItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8" Spacing="{StaticResource EchoBoardSpace4}">
                                                <TextBlock
                                                    Text="{Binding FileName}"
                                                    Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                                                    FontWeight="SemiBold" />
                                                <TextBlock
                                                    Text="{Binding Message}"
                                                    Style="{StaticResource EchoBoardCaptionTextStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <controls:EmptyState
                            Icon="Audio"
                            Title="{Binding EmptyStateTitle}"
                            Description="{Binding EmptyStateMessage}"
                            Visibility="{Binding EmptyStateVisibility}" />

                        <GridView
                            ItemsSource="{Binding Sounds}"
                            IsItemClickEnabled="False"
                            SelectionMode="None"
                            Visibility="{Binding SoundGridVisibility}">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <controls:SoundCard
                                        Width="236"
                                        Margin="0,0,12,12"
                                        Title="{Binding Title}"
                                        Subtitle="{Binding Subtitle}"
                                        DurationText="{Binding DurationText}"
                                        HotkeyText="{Binding HotkeyText}"
                                        CategoryLabel="{Binding CategoryLabel}"
                                        CategoryBrush="{Binding CategoryBrush}"
                                        IsSelected="{Binding IsSelected}"
                                        IsPlaying="{Binding IsPlaying}"
                                        IsPaused="{Binding IsPaused}"
                                        IsFavorite="{Binding IsFavorite}"
                                        IsMissingFile="{Binding IsMissingFile}"
                                        StatusText="{Binding StatusText}"
                                        IsCompact="{Binding IsCompact}"
                                        IsEnabled="{Binding IsEnabled}"
                                        Command="{Binding SelectCommand}"
                                        CommandParameter="{Binding Id}"
                                        FavoriteCommand="{Binding FavoriteCommand}"
                                        FavoriteCommandParameter="{Binding Id}"
                                        FormatText="{Binding FormatText}"
                                        UsageText="{Binding UsageText}"
                                        WaveformBars="{Binding WaveformBars}"
                                        DetailsCommand="{Binding DetailsCommand}"
                                        EditCommand="{Binding EditCommand}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
