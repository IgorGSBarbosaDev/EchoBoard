<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="EchoBoardShellIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource EchoBoardTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource EchoBoardRadiusMedium}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource EchoBoardSurfaceHoverBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource EchoBoardBorderBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource EchoBoardTextPrimaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource EchoBoardCardActiveBrush}" />
                                        <Setter Target="Root.BorderBrush" Value="{ThemeResource EchoBoardActionBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource EchoBoardTextPrimaryBrush}" />
                                        <Setter Target="Root.Opacity" Value="0.86" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.42" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Foreground="{TemplateBinding Foreground}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EchoBoardTransportPlayButtonStyle" TargetType="Button" BasedOn="{StaticResource EchoBoardShellIconButtonStyle}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Background" Value="{ThemeResource EchoBoardActionBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource EchoBoardActionBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource EchoBoardOnActionBrush}" />
    </Style>

    <Style x:Key="EchoBoardSoundCardButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource EchoBoardSurfaceHoverBrush}" />
                                        <Setter Target="Root.Opacity" Value="0.98" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{ThemeResource EchoBoardCardActiveBrush}" />
                                        <Setter Target="Root.Opacity" Value="0.86" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.48" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EchoBoardShellStatusChipStyle" TargetType="Border">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="11,6" />
        <Setter Property="Background" Value="{ThemeResource EchoBoardCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource EchoBoardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource EchoBoardRadiusLarge}" />
    </Style>

    <Style x:Key="EchoBoardContextPanelStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource EchoBoardContextPanelWidth}" />
        <Setter Property="Background" Value="{ThemeResource EchoBoardBackgroundElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource EchoBoardBorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>

    <Style x:Key="EchoBoardTransportSurfaceStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="{StaticResource EchoBoardTransportHeight}" />
        <Setter Property="Padding" Value="{StaticResource EchoBoardTransportPadding}" />
        <Setter Property="Background" Value="{ThemeResource EchoBoardBackgroundElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource EchoBoardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>
</ResourceDictionary>
