<UserControl
    x:Class="EchoBoard.App.Controls.HotkeyCaptureBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="{StaticResource EchoBoardSpace8}">
        <StackPanel
            Orientation="Horizontal"
            Spacing="{StaticResource EchoBoardSpace8}">
            <CheckBox Content="Ctrl" IsChecked="{x:Bind Ctrl, Mode=TwoWay}" />
            <CheckBox Content="Alt" IsChecked="{x:Bind Alt, Mode=TwoWay}" />
            <CheckBox Content="Shift" IsChecked="{x:Bind Shift, Mode=TwoWay}" />
            <CheckBox Content="Win" IsChecked="{x:Bind Win, Mode=TwoWay}" />
        </StackPanel>
        <TextBox
            Header="Primary key"
            PlaceholderText="F8, S, PageDown"
            Text="{x:Bind PrimaryKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>
</UserControl>
