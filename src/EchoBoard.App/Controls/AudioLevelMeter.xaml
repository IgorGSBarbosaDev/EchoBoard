<UserControl
    x:Class="EchoBoard.App.Controls.AudioLevelMeter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="120"
    AutomationProperties.Name="{x:Bind AccessibleLabel, Mode=OneTime}">
    <StackPanel Spacing="{StaticResource EchoBoardSpace4}">
        <Grid ColumnSpacing="{StaticResource EchoBoardSpace8}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Text="{x:Bind Label, Mode=OneTime}"
                Style="{StaticResource EchoBoardCaptionTextStyle}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Grid.Column="1"
                Text="{x:Bind DisplayValue, Mode=OneTime}"
                Foreground="{ThemeResource EchoBoardTextSecondaryBrush}"
                FontSize="{StaticResource EchoBoardFontSizeBadge}"
                FontWeight="SemiBold" />
        </Grid>

        <Border
            Height="8"
            Background="{ThemeResource EchoBoardDisabledBrush}"
            CornerRadius="{StaticResource EchoBoardRadiusSmall}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{x:Bind FilledWidth, Mode=OneTime}" />
                    <ColumnDefinition Width="{x:Bind EmptyWidth, Mode=OneTime}" />
                </Grid.ColumnDefinitions>
                <Border
                    Background="{x:Bind MeterBrush, Mode=OneTime}"
                    CornerRadius="{StaticResource EchoBoardRadiusSmall}" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
