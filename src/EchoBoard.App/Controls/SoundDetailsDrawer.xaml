<UserControl
    x:Class="EchoBoard.App.Controls.SoundDetailsDrawer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:EchoBoard.App.Controls">
    <Border
        Background="{ThemeResource EchoBoardBackgroundElevatedBrush}"
        BorderBrush="{ThemeResource EchoBoardBorderBrush}"
        BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="16" Spacing="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Detalhes do som" Style="{StaticResource EchoBoardSectionTitleTextStyle}" />
                        <TextBlock Text="Seleção atual" Style="{StaticResource EchoBoardCaptionTextStyle}" />
                    </StackPanel>
                    <Button
                        x:Name="CloseButton"
                        Grid.Column="1"
                        AutomationProperties.Name="Fechar detalhes"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource EchoBoardIconButtonStyle}">
                        <FontIcon Glyph="&#xE711;" />
                    </Button>
                </Grid>

                <Border Height="96" Background="{ThemeResource EchoBoardCardBrush}" BorderBrush="{ThemeResource EchoBoardBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource EchoBoardRadiusLarge}">
                    <SymbolIcon Symbol="Audio" Foreground="{ThemeResource EchoBoardActionBrush}" />
                </Border>

                <StackPanel Spacing="3" Visibility="{Binding ReadOnlyVisibility}">
                    <TextBlock Text="{Binding Title}" Foreground="{ThemeResource EchoBoardTextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Metadata}" Style="{StaticResource EchoBoardCaptionTextStyle}" />
                </StackPanel>

                <TextBox Header="Nome" Text="{Binding Name, Mode=TwoWay}" Visibility="{Binding EditVisibility}" />

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Button Command="{Binding PlayCommand}" Style="{StaticResource EchoBoardPrimaryButtonStyle}" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Play" /><TextBlock Text="Reproduzir" /></StackPanel>
                    </Button>
                    <Button Grid.Column="1" Command="{Binding BeginEditCommand}" Style="{StaticResource EchoBoardSecondaryButtonStyle}" HorizontalAlignment="Stretch" Visibility="{Binding ReadOnlyVisibility}">
                        <StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Edit" /><TextBlock Text="Editar" /></StackPanel>
                    </Button>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Visibility="{Binding EditVisibility}">
                        <Button Content="Salvar" Command="{Binding SaveCommand}" Style="{StaticResource EchoBoardPrimaryButtonStyle}" />
                        <Button Content="Cancelar" Command="{Binding CancelEditCommand}" Style="{StaticResource EchoBoardSecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding FeedbackMessage}" Foreground="{ThemeResource EchoBoardTextSecondaryBrush}" TextWrapping="Wrap" Visibility="{Binding FeedbackVisibility}" />

                <StackPanel Spacing="9">
                    <TextBlock Text="ATALHO" Foreground="{ThemeResource EchoBoardTextSecondaryBrush}" FontSize="10" FontWeight="SemiBold" CharacterSpacing="80" />
                    <Grid><TextBlock Text="Hotkey global" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding HotkeyText}" Foreground="{ThemeResource EchoBoardTextPrimaryBrush}" /></Grid>
                    <Grid><TextBlock Text="Registro" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding HotkeyStatusText}" Foreground="{ThemeResource EchoBoardSuccessBrush}" /></Grid>
                    <controls:HotkeyCaptureBox
                        Ctrl="{Binding HotkeyCtrl, Mode=TwoWay}"
                        Alt="{Binding HotkeyAlt, Mode=TwoWay}"
                        Shift="{Binding HotkeyShift, Mode=TwoWay}"
                        Win="{Binding HotkeyWin, Mode=TwoWay}"
                        PrimaryKey="{Binding HotkeyPrimaryKey, Mode=TwoWay}"
                        Visibility="{Binding EditVisibility}" />
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource EchoBoardBorderSoftBrush}" />

                <StackPanel Spacing="9">
                    <TextBlock Text="REPRODUÇÃO" Foreground="{ThemeResource EchoBoardTextSecondaryBrush}" FontSize="10" FontWeight="SemiBold" CharacterSpacing="80" />
                    <Grid><TextBlock Text="Volume individual" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding VolumeText}" /></Grid>
                    <Slider Minimum="0" Maximum="100" Value="{Binding VolumePercent, Mode=TwoWay}" IsEnabled="{Binding IsEditing}" />
                    <Grid><TextBlock Text="Loop" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding LoopText}" Visibility="{Binding ReadOnlyVisibility}" /><ToggleSwitch HorizontalAlignment="Right" IsOn="{Binding IsLoopEnabled, Mode=TwoWay}" Visibility="{Binding EditVisibility}" /></Grid>
                    <Grid><TextBlock Text="Interromper som anterior" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding StopPreviousText}" Visibility="{Binding ReadOnlyVisibility}" /><ToggleSwitch HorizontalAlignment="Right" IsOn="{Binding StopPreviousSound, Mode=TwoWay}" Visibility="{Binding EditVisibility}" /></Grid>
                    <Grid><TextBlock Text="Permitir sobreposição" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding AllowOverlapText}" Visibility="{Binding ReadOnlyVisibility}" /><ToggleSwitch HorizontalAlignment="Right" IsOn="{Binding AllowOverlap, Mode=TwoWay}" Visibility="{Binding EditVisibility}" /></Grid>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource EchoBoardBorderSoftBrush}" />

                <StackPanel Spacing="9">
                    <TextBlock Text="ORGANIZAÇÃO" Foreground="{ThemeResource EchoBoardTextSecondaryBrush}" FontSize="10" FontWeight="SemiBold" CharacterSpacing="80" />
                    <Grid><TextBlock Text="Categoria" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding CategoryText}" Visibility="{Binding ReadOnlyVisibility}" /></Grid>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" DisplayMemberPath="Name" Visibility="{Binding EditVisibility}" HorizontalAlignment="Stretch" />
                    <Grid><TextBlock Text="Favorito" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding FavoriteText}" Visibility="{Binding ReadOnlyVisibility}" /><ToggleSwitch HorizontalAlignment="Right" IsOn="{Binding IsFavorite, Mode=TwoWay}" Visibility="{Binding EditVisibility}" /></Grid>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource EchoBoardBorderSoftBrush}" />

                <StackPanel Spacing="9">
                    <TextBlock Text="ARQUIVO" Foreground="{ThemeResource EchoBoardTextSecondaryBrush}" FontSize="10" FontWeight="SemiBold" CharacterSpacing="80" />
                    <TextBlock Text="Caminho" Style="{StaticResource EchoBoardCaptionTextStyle}" />
                    <TextBlock Text="{Binding FilePath}" TextWrapping="Wrap" Foreground="{ThemeResource EchoBoardTextPrimaryBrush}" />
                    <Grid><TextBlock Text="Tamanho" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding FileSizeText}" /></Grid>
                    <Grid><TextBlock Text="Disponibilidade" Style="{StaticResource EchoBoardCaptionTextStyle}" /><TextBlock HorizontalAlignment="Right" Text="{Binding AvailabilityText}" Foreground="{ThemeResource EchoBoardSuccessBrush}" /></Grid>
                </StackPanel>

                <Button Click="OnRemoveClicked" HorizontalAlignment="Stretch" Style="{StaticResource EchoBoardSecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="7"><SymbolIcon Symbol="Delete" Foreground="{ThemeResource EchoBoardErrorBrush}" /><TextBlock Text="Remover da biblioteca" Foreground="{ThemeResource EchoBoardErrorBrush}" /></StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
