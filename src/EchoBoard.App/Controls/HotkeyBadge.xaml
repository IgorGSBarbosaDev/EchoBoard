<UserControl
    x:Class="EchoBoard.App.Controls.HotkeyBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinHeight="24"
    AutomationProperties.Name="{x:Bind AutomationName, Mode=OneTime}">
    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AvailabilityStates">
                <VisualState x:Name="Available" />
                <VisualState x:Name="Disabled">
                    <VisualState.Setters>
                        <Setter Target="BadgeText.Foreground" Value="{ThemeResource EchoBoardTextSecondaryBrush}" />
                        <Setter Target="BadgeBorder.BorderBrush" Value="{ThemeResource EchoBoardBorderBrush}" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Conflicting">
                    <VisualState.Setters>
                        <Setter Target="BadgeText.Foreground" Value="{ThemeResource EchoBoardWarningBrush}" />
                        <Setter Target="BadgeBorder.BorderBrush" Value="{ThemeResource EchoBoardWarningBrush}" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Unavailable">
                    <VisualState.Setters>
                        <Setter Target="BadgeText.Foreground" Value="{ThemeResource EchoBoardTextDisabledBrush}" />
                        <Setter Target="BadgeBorder.BorderBrush" Value="{ThemeResource EchoBoardBorderBrush}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Border
            x:Name="BadgeBorder"
            Padding="{StaticResource EchoBoardBadgePadding}"
            Background="{ThemeResource EchoBoardCardActiveBrush}"
            BorderBrush="{ThemeResource EchoBoardActionBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource EchoBoardRadiusPill}">
            <TextBlock
                x:Name="BadgeText"
                Text="{x:Bind DisplayText, Mode=OneTime}"
                Foreground="{ThemeResource EchoBoardTextPrimaryBrush}"
                FontSize="{StaticResource EchoBoardFontSizeBadge}"
                FontWeight="SemiBold"
                TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</UserControl>
